# ai-translation — example environment variables.
# Copy to `.env` and fill in the values you need. Everything here is optional
# unless you're using the matching feature (e.g. the Azure/Gemini keys are
# only required if RAG_LLM selects that provider).

# ---------- LLM selection -----------------------------------------------------
# Which LLM adapter `make_llm_client()` returns. Default is `null` (no-op, for
# dry runs and tests). Set to one of: null | claude | azure-openai | gemini.
RAG_LLM=azure-openai

# ---------- Azure OpenAI (required when RAG_LLM=azure-openai) -----------------
AZURE_OPENAI_ENDPOINT=https://<your-resource>.services.ai.azure.com/models
AZURE_OPENAI_API_KEY=<your-azure-openai-api-key>
AZURE_OPENAI_DEPLOYMENT=<your-deployment-name>
AZURE_OPENAI_API_VERSION=2024-08-01-preview

# ---------- Google Gemini (required when RAG_LLM=gemini) ----------------------
# Either GEMINI_API_KEY or GOOGLE_API_KEY works; the first one set wins.
GEMINI_API_KEY=<your-gemini-api-key>
# GOOGLE_API_KEY=
GEMINI_MODEL=gemini-3.1-pro-preview

# ---------- Knowledge base (RAG retrieval) -----------------------------------
# Markdown vault that `kb index` reads from.
KB_VAULT=./vault
# Where the vector store + JSON indexes + lookup cache live.
KB_STORE_PATH=./.kb
# Embedder selection: `local` (sentence-transformers) or `openai`.
KB_EMBEDDER=local
# Model name for the selected embedder.
KB_EMBEDDER_MODEL=BAAI/bge-m3

# ---------- Pipeline runner ---------------------------------------------------
# Which orchestrator to use. `simple` is the hand-rolled topological runner;
# `langgraph` is reserved for a future LangGraph-backed runner.
RAG_PIPELINE=simple

# ---------- HTTP API ----------------------------------------------------------
# Where `translate-api` persists run scratchpads. Defaults to `.translate-runs`.
RAG_API_RUNS_DIR=./.translate-runs
